{
    "manifest_version": 3,
    "name": "FlowMind AI",
    "version":"1.0",
    "description" : "AI assistant for selected text",
    "permissions": ["activeTab", "scripting"],
    "host_permissions": [
        "http://localhost:8000/*"
        ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css":["style.css"]

    }

    ]
}
